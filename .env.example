# Set ONE of these API keys (whichever provider you have):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Scraping settings
COMMENT_THRESHOLD=300        # min comments on a video to scrape it
MAX_COMMENTS_PER_VIDEO=30    # how many comments to grab per video
MAX_VIDEOS=0                 # auto-stop after this many scraped videos (0 = unlimited)

# Server
HOST=127.0.0.1
PORT=8000
